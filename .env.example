# ──────────────────────────────────────────
# Servidor
# ──────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ──────────────────────────────────────────
# WhatsApp Business Cloud API (Meta)
# ──────────────────────────────────────────
WHATSAPP_API_URL=https://graph.facebook.com/v19.0
WHATSAPP_PHONE_NUMBER_ID=tu_phone_number_id
WHATSAPP_ACCESS_TOKEN=tu_access_token
WHATSAPP_VERIFY_TOKEN=tu_verify_token

# ──────────────────────────────────────────
# Google Sheets API
# ──────────────────────────────────────────
GOOGLE_SHEETS_ID=tu_spreadsheet_id
GOOGLE_SERVICE_ACCOUNT_EMAIL=tu_service_account@proyecto.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\ntu_clave_privada\n-----END PRIVATE KEY-----"

# ──────────────────────────────────────────
# Zoom API
# ──────────────────────────────────────────
ZOOM_ACCOUNT_ID=tu_zoom_account_id
ZOOM_CLIENT_ID=tu_zoom_client_id
ZOOM_CLIENT_SECRET=tu_zoom_client_secret

# ──────────────────────────────────────────
# Landing Page
# ──────────────────────────────────────────
VSL_VIDEO_URL=https://www.youtube.com/embed/tu_video_id
LANDING_URL=http://localhost:3000
CALENDLY_URL=https://calendly.com/tu-reunion
REUNION_GRUPAL_URL=https://calendly.com/tu-reunion-grupal

# ──────────────────────────────────────────
# Agente
# ──────────────────────────────────────────
EMPRESA_NOMBRE=Three Inmobiliaria
EXPERTO_NOMBRE=Nombre del Experto
REMINDER_INTERVAL_HOURS=48
MAX_REMINDERS=3
DELAYED_BUTTON_SECONDS=300
